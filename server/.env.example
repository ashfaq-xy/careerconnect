# PRD v2 §10.1 — Server Environment Variables

# Server
PORT=8000
NODE_ENV=development

# MongoDB Atlas (PRD v2 §3.1)
# The db.js config uses dbName: 'careerconnect' which overrides the URI database name
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/careerconnect

# JWT Secrets — minimum 32 random characters each (PRD v2 §8)
JWT_ACCESS_SECRET=your_access_token_secret_minimum_32_chars_here
JWT_REFRESH_SECRET=your_refresh_token_secret_minimum_32_chars_here

# Frontend URL — used for CORS origin and password reset links (PRD v2 §10.3)
# Development:
CLIENT_URL=http://localhost:3000
# Production example:
# CLIENT_URL=https://careerconnect.example.com

# Email — Gmail SMTP with App Password (PRD v2 §10.1)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=your_gmail_app_password_16_chars
