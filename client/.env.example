# PRD v2 §10.2 — Client Environment Variables

# Backend API base URL
# Development:
VITE_API_URL=http://localhost:8000/api/v1
# Production example:
# VITE_API_URL=https://api.careerconnect.example.com/api/v1

# Socket.IO server URL (PRD v2 §6.1)
# Development:
VITE_SOCKET_URL=http://localhost:8000
# Production example:
# VITE_SOCKET_URL=https://api.careerconnect.example.com

# App name displayed in page titles
VITE_APP_NAME=CareerConnect
